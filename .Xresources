! set font
!URxvt.font: -*-terminus-*-*-*-*-12-*-*-*-*-*-*-*
URxvt.font: xft:Inconsolata:pixelsize=13

! fix font spacing
!URxvt.letterSpace: -1

! change scrollbar style
URxvt.scrollstyle: plain
URxvt.scrollBar_right: true

! do not scroll with output
URxvt.scrollTtyOutput: false
URxvt.scrollTtyKeypress: true

! disable perl extensions (include matcher plugin for links)
URxvt.perl-ext:
URxvt.perl-ext-common: matcher

! enable links
URxvt.url-launcher: /usr/bin/xdg-open
URxvt.matcher.button: 1

! search scrollback
URxvt.keysym.M-s: searchable-scrollback:start

! jump words with ctrl + right/left
URxvt.keysym.Control-Left: \033[1;5D
URxvt.keysym.Control-Right: \033[1;5C

! use apprentice colorscheme
*.foreground: #BCBCBC
*.background: #262626
*.color0:     #1C1C1C
*.color8:     #444444
*.color1:     #AF5F5F
*.color9:     #FF8700
*.color2:     #5F875F
*.color10:    #87AF87
*.color3:     #87875F
*.color11:    #FFFFAF
*.color4:     #5F87AF
*.color12:    #8FAFD7
*.color5:     #5F5F87
*.color13:    #8787AF
*.color6:     #5F8787
*.color14:    #5FAFAF
*.color7:     #6C6C6C
*.color15:    #FFFFFF
